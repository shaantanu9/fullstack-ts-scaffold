# Application
NODE_ENV=development
PORT=5004
CLIENT_URL=http://localhost:3000
API_PREFIX=/api/v1

# Supabase
# Local dev: run `supabase start`, then `supabase status -o env` to print your
# local keys and paste them below (they only work against 127.0.0.1:54321).
# Hosted project: use your project URL + the SERVICE-ROLE key from
# Project Settings > API (keep the service-role key secret — never commit it).
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
SUPABASE_ANON_KEY=your-local-anon-key

# Redis
REDIS_URL=redis://localhost:6383

# Authentication
ACCESS_TOKEN_SECRET=change-me-access-token-secret-min-32-chars-long
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=change-me-refresh-token-secret-min-32-chars-long
REFRESH_TOKEN_EXPIRY=7d

# Logging
LOG_LEVEL=info

# ImageKit (optional — direct-to-CDN image uploads). Get keys at https://imagekit.io/dashboard.
# Leave blank to disable; GET /api/v1/uploads/imagekit-auth returns 503 until all three are set.
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
