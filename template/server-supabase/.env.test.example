NODE_ENV=test
PORT=5004
CLIENT_URL=http://localhost:3000
API_PREFIX=/api/v1

# Supabase local stack (from `supabase start`). These keys ONLY work against the
# local 127.0.0.1:54321 stack. Get your local values with `supabase status -o env`
# (or the Studio) and paste them here in `.env.test` before running supabase tests.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
SUPABASE_ANON_KEY=your-local-anon-key

REDIS_URL=redis://localhost:6383
ACCESS_TOKEN_SECRET=test-access-token-secret-32-chars-long
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=test-refresh-token-secret-32-chars-long
REFRESH_TOKEN_EXPIRY=7d
LOG_LEVEL=error

# Fake ImageKit creds so the upload-auth endpoint is exercised in tests.
IMAGEKIT_PUBLIC_KEY=public_test_key
IMAGEKIT_PRIVATE_KEY=private_test_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/testboilerplate
