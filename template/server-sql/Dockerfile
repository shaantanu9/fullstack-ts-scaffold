# Self-contained image for the Postgres/Prisma backend.
# Build context is THIS folder, so it does not depend on the pnpm workspace or
# the other server folder — you can delete server-mongo/ and this still builds:
#   docker build -t boilerplate-server-sql server-sql
#   docker run -p 5002:5002 --env-file server-sql/.env boilerplate-server-sql

# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

RUN npm install -g pnpm@9

COPY package.json ./
RUN pnpm install --no-frozen-lockfile

COPY . .
RUN pnpm db:generate && pnpm build
RUN pnpm prune --prod

# Production stage
FROM node:20-alpine AS production

WORKDIR /app

ENV NODE_ENV=production

RUN apk add --no-cache dumb-init

COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./package.json
# Prisma client + schema are needed at runtime.
COPY --from=builder /app/src/database/prisma ./src/database/prisma

EXPOSE 5002

USER node

CMD ["dumb-init", "node", "dist/server.js"]
