NODE_ENV=test
PORT=5003
CLIENT_URL=http://localhost:3000
API_PREFIX=/api/v1

# Database
DATABASE_URL=mongodb://mongo:mongo@localhost:27018/boilerplate_test?authSource=admin

REDIS_URL=redis://localhost:6382
ACCESS_TOKEN_SECRET=test-access-token-secret-32-chars-long
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=test-refresh-token-secret-32-chars-long
REFRESH_TOKEN_EXPIRY=7d
LOG_LEVEL=error

# Fake ImageKit creds so the upload-auth endpoint is exercised in tests.
IMAGEKIT_PUBLIC_KEY=public_test_key
IMAGEKIT_PRIVATE_KEY=private_test_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/testboilerplate
