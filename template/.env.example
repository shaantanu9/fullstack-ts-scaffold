# Reference example (server-sql / Postgres defaults). Each backend has its own
# .env.example — server-mongo runs on PORT=5003 with REDIS_URL=redis://localhost:6382
# and a mongodb:// DATABASE_URL, so the two backends never collide.

# Client
NEXT_PUBLIC_API_BASE_URL=http://localhost:5002/api/v1

# Server
NODE_ENV=development
PORT=5002
CLIENT_URL=http://localhost:3000
API_PREFIX=/api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/boilerplate_db?schema=public
REDIS_URL=redis://localhost:6381
ACCESS_TOKEN_SECRET=change-me-access-token-secret-min-32-chars-long
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=change-me-refresh-token-secret-min-32-chars-long
REFRESH_TOKEN_EXPIRY=7d
LOG_LEVEL=info

# ImageKit (optional — image uploads). Blank = disabled (endpoint returns 503).
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
