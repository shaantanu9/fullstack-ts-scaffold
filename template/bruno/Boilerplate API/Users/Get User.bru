meta {
  name: Get User
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/users/{{userId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return the requested user", function() {
    const json = res.getBody();
    expect(json.success).to.be.true;
    expect(json.data.id).to.equal(bru.getVar("userId"));
  });
}
